    "indexScript": "<script>\ndocument.addEventListener(\"DOMContentLoaded\",function(){\n    var content=document.getElementById('content');\n    if(!content){return;}\n    var hitokotoContainer=document.createElement('div');\n    hitokotoContainer.id='hitokoto-container';\n    hitokotoContainer.innerHTML='<span id=\"hitokoto-text\">\\u52a0\\u8f7d\\u4e2d...</span><span id=\"hitokoto-from\"></span><span id=\"hitokoto-refresh\" onclick=\"loadHitokoto()\">\\u6362\\u4e00\\u53e5</span>';\n    var firstDiv=content.querySelector('div');\n    if(firstDiv){\n        firstDiv.insertAdjacentElement('afterend',hitokotoContainer);\n    }else{\n        content.insertBefore(hitokotoContainer,content.firstChild);\n    }\n    loadHitokoto();\n});\nfunction loadHitokoto(){\n    var textEl=document.getElementById('hitokoto-text');\n    var fromEl=document.getElementById('hitokoto-from');\n    if(!textEl){return;}\n    var xhr=new XMLHttpRequest();\n    xhr.open('GET','https://v1.hitokoto.cn/?encode=json&c=d&c=i&c=k');\n    xhr.responseType='text';\n    xhr.timeout=5000;\n    xhr.onload=function(){\n        try{\n            var data=JSON.parse(xhr.response);\n            textEl.textContent=data.hitokoto||'\\u751f\\u6d3b\\u603b\\u4f1a\\u6709\\u5e0c\\u671b\\u3002';\n            fromEl.textContent=data.from?('\\u2014\\u2014 '+data.from):'';\n        }catch(e){\n            textEl.textContent='\\u4eba\\u751f\\u5982\\u9006\\u65c5\\uff0c\\u6211\\u4e5f\\u662f\\u884c\\u4eba\\u3002';\n            fromEl.textContent='\\u2014\\u2014 \\u82cf\\u8f7c';\n        }\n    };\n    xhr.onerror=xhr.ontimeout=function(){\n        textEl.textContent='\\u4eba\\u751f\\u5982\\u9006\\u65c5\\uff0c\\u6211\\u4e5f\\u662f\\u884c\\u4eba\\u3002';\n        fromEl.textContent='\\u2014\\u2014 \\u82cf\\u8f7c';\n    };\n    xhr.send();\n}\n</script>",
    "indexStyle": "<style>\n#hitokoto-container{margin-bottom:16px;padding:12px 16px;background-color:var(--color-canvas-subtle,#f6f8fa);border-left:3px solid #0969da;border-radius:4px;font-size:14px;line-height:1.6;color:var(--color-fg-muted,#57606a);display:flex;align-items:center;gap:8px;flex-wrap:wrap;}\n#hitokoto-text{flex:1;min-width:0;font-style:italic;}\n#hitokoto-from{font-size:12px;color:var(--color-fg-subtle,#6e7781);}\n#hitokoto-refresh{cursor:pointer;color:#0969da;font-size:12px;white-space:nowrap;user-select:none;}\n#hitokoto-refresh:hover{text-decoration:underline;}\n</style>",
