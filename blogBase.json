{"singlePage": [], "startSite": "", "filingNum": "", "onePageListNum": 15, "commentLabelColor": "#006b75", "yearColorList": ["#bc4c00", "#0969da", "#1f883d", "#A333D0"], "i18n": "CN", "themeMode": "manual", "dayTheme": "light", "nightTheme": "dark", "urlMode": "pinyin", "script": "", "style": "", "head": "", "indexScript": "<script>\ndocument.addEventListener(\"DOMContentLoaded\",function(){\n    var content=document.getElementById('content');\n    if(!content){return;}\n    var hitokotoContainer=document.createElement('div');\n    hitokotoContainer.id='hitokoto-container';\n    hitokotoContainer.innerHTML='<span id=\"hitokoto-text\">\u52a0\u8f7d\u4e2d...</span><span id=\"hitokoto-from\"></span><span id=\"hitokoto-refresh\" onclick=\"loadHitokoto()\">\u6362\u4e00\u53e5</span>';\n    var firstDiv=content.querySelector('div');\n    if(firstDiv){firstDiv.insertAdjacentElement('afterend',hitokotoContainer);}else{content.insertBefore(hitokotoContainer,content.firstChild);}\n    loadHitokoto();\n});\nfunction loadHitokoto(){\n    var textEl=document.getElementById('hitokoto-text');\n    var fromEl=document.getElementById('hitokoto-from');\n    if(!textEl){return;}\n    var xhr=new XMLHttpRequest();\n    xhr.open('GET','https://v1.hitokoto.cn/?encode=json&c=d&c=i&c=k');\n    xhr.responseType='text';\n    xhr.timeout=5000;\n    xhr.onload=function(){\n        try{var data=JSON.parse(xhr.response);textEl.textContent=data.hitokoto||'\u751f\u6d3b\u603b\u4f1a\u6709\u5e0c\u671b\u3002';fromEl.textContent=data.from?('\u2014\u2014 '+data.from):'';}\n        catch(e){textEl.textContent='\u4eba\u751f\u5982\u9006\u65c5\uff0c\u6211\u4ea6\u662f\u884c\u4eba\u3002';fromEl.textContent='\u2014\u2014 \u82cf\u8f7c';}\n    };\n    xhr.onerror=xhr.ontimeout=function(){textEl.textContent='\u4eba\u751f\u5982\u9006\u65c5\uff0c\u6211\u4ea6\u662f\u884c\u4eba\u3002';fromEl.textContent='\u2014\u2014 \u82cf\u8f7c';};\n    xhr.send();\n}\n</script>", "indexStyle": "<style>\n#hitokoto-container{margin-bo