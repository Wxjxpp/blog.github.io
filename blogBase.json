'<span style=\"margin-right:8px;color:var(--color-fg-muted);\">\u5206\u4eab\u5230:</span>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareWebShare()\" title=\"\u5206\u4eab\" style=\"font-size:small;\">\u5206\u4eab</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareTo(\\'weibo\\')\" title=\"\u5fae\u535a\" style=\"font-size:small;\">\u5fae\u535a</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareTo(\\'twitter\\')\" title=\"Twitter\" style=\"font-size:small;\">Twitter</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareTo(\\'facebook\\')\" title=\"Facebook\" style=\"font-size:small;\">Facebook</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:copyShareLink()\" title=\"\u590d\u5236\u94fe\u63a5\" style=\"font-size:small;\">\u590d\u5236\u94fe\u63a5</a>';\n        var bottomDiv=postBody.nextElementSibling;\n        if(bottomDiv && bottomDiv.getAttribute('style') && bottomDiv.getAttribute('style').indexOf('float:right')!==-1){\n            bottomDiv.insertAdjacentElement('afterend',shareBox);\n        }else{\n            postBody.insertAdjacentElement('afterend',shareBox);\n        }\n    }\n});\nfunction shareWebShare(){\n    if(navigator.share){\n        var desc='';\n        var metaDesc=document.querySelector('meta[name=\"description\"]');\n        if(metaDesc){desc=metaDesc.getAttribute('content')||'';}\n        navigator.share({title:document.title,url:window.location.href,text:desc}).catch(function(err){console.log('Share canceled:',err);});\n    }else{copyShareLink();}\n}\nfunction shareTo(platform){\n    var url=encodeURIComponent(window.location.href);\n    var title=encodeURIComponent(document.title);\n    var shareUrl='';\n    if(platform==='weibo'){shareUrl='https://service.weibo.com/share/share.php?url='+url+'&title='+title;}\n    else if(platform==='twitter'){shareUrl='https://twitter.com/intent/tweet?url='+url+'&text='+title;}\n    else if(platform==='facebook'){shareUrl='https://www.facebook.com/sharer/sharer.php?u='+url;}\n    if(shareUrl){window.open(shareUrl,'_blank','width=600,height=500,menubar=no,toolbar=no');}\n}\nfunction copyShareLink(){\n    var url=window.location.href;\n    if(navigator.clipboard && navigator.clipboard.writeText){\n        navigator.clipboard.writeText(url).then(function(){alert('\u94fe\u63a5\u5df2\u590d\u5236\\n'+url);}).catch(function(){fallbackCopy(url);});\n    }else{fallbackCopy(url);}\n}\nfunction fallbackCopy(url){\n    var textarea=document.createElement('textarea');\n    textarea.value=url;\n    textarea.style.position='fixed';\n    textarea.style.opacity='0';\n    document.body.appendChild(textarea);\n    textarea.select();\n    try{document.execCommand('copy');alert('\u94fe\u63a5\u5df2\u590d\u5236\\n'+url);}catch(e){prompt('\u8bf7\u590d\u5236\u4e0b\u9762\u7684\u94fe\u63a5:',url);}\n    document.body.removeChild(textarea);\n}\n</script>", "title": "Blog Title", "subTitle": "Blog description", "avatarUrl": "https://github.githubassets.com/favicons/favicon.svg", "GMEEK_VERSION": "last", "postListJson": {"P2": {"htmlDir": "docs/post/Blog-ce-shi.html", "labels": ["\u7ed3\u679c"], "postTitle": "Blog\u6d4b\u8bd5", "postUrl": "post/Blog-ce-shi.html", "postSourceUrl": "https://github.com/Wxjxpp/blog.github.io/issues/2", "commentNum": 1, "wordCount": 7, "description": "1234567\u3002", "top": 0, "createdAt": 1784473718, "style": "", "script": "", "head": "", "ogImage": "https://github.githubassets.com/favicons/favicon.svg", "createdDate": "2026-07-19", "dateLabelColor": "#1f883d"}, "P3": {"htmlDir": "docs/post/huo-li-man-man-de-yi-tian.html", "labels": ["\u65e5\u5e38"], "postTitle": "\u6d3b\u529b\u6ee1\u6ee1\u7684\u4e00\u5929", "postUrl": "post/huo-li-man-man-de-yi-tian.html", "postSourceUrl": "https://github.com/Wxjxpp/blog.github.io/issues/3", "commentNum": 0, "wordCount": 16, "description": "\u65e9\u6668\u8d77\u5e8a\uff0c\u62e5\u62b1\u592a\u9633\uff0c\u6ee1\u6ee1\u7684\u6b63\u80f