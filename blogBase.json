    "allHead": "<script>\ndocument.addEventListener(\"DOMContentLoaded\",function(){\n    // ===== Visitor Counter (Vercount) =====\n    var postBody=document.getElementById('postBody');\n    if(postBody){\n        postBody.insertAdjacentHTML('afterend','<div id=\"busuanzi_container_page_pv\" style=\"display:none;float:left;margin-top:8px;font-size:small;\">\\u672c\\u6587\\u6d4f\\u89c8\\u91cf <span id=\"busuanzi_value_page_pv\"></span> \\u6b21</div>');\n    }\n    var runday=document.getElementById('runday');\n    if(runday){\n        runday.insertAdjacentHTML('afterend','<span id=\"busuanzi_container_site_pv\" style=\"display:none\">\\u603b\\u6d4f\\u89c8\\u91cf <span id=\"busuanzi_value_site_pv\"></span> \\u6b21 \\u2022 </span>');\n        runday.insertAdjacentHTML('afterend','<span id=\"busuanzi_container_site_uv\" style=\"display:none\">\\u8bbf\\u5ba2\\u6570 <span id=\"busuanzi_value_site_uv\"></span> \\u2022 </span>');\n        var vc=document.createElement('script');\n        vc.src='https://vercount.one/js';\n        vc.async=true;\n        document.head.appendChild(vc);\n    }\n\n    // ===== Share buttons (only on post pages) =====\n    if(postBody){\n        var shareBox=document.createElement('div');\n        shareBox.id='share-box';\n        shareBox.style.cssText='margin-top:24px;padding:16px 0;border-top:1px solid var(--color-border-muted, #d0d7de);text-align:center;font-size:small;clear:both;';\n        shareBox.innerHTML='<span style=\"margin-right:8px;color:var(--color-fg-muted);\">\\u5206\\u4eab\\u5230:</span>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareWebShare()\" title=\"\\u5206\\u4eab\" style=\"font-size:small;\">\\u5206\\u4eab</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareTo(\\'weibo\\')\" title=\"\\u5fae\\u535a\" style=\"font-size:small;\">\\u5fae\\u535a</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareTo(\\'twitter\\')\" title=\"Twitter\" style=\"font-size:small;\">Twitter</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareTo(\\'facebook\\')\" title=\"Facebook\" style=\"font-size:small;\">Facebook</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:copyShareLink()\" title=\"\\u590d\\u5236\\u94fe\\u63a5\" style=\"font-size:small;\">\\u590d\\u5236\\u94fe\\u63a5</a>';\n        var bottomDiv=postBody.nextElementSibling;\n        if(bottomDiv && bottomDiv.getAttribute('style') && bottomDiv.getAttribute('style').indexOf('float:right')!==-1){\n            bottomDiv.insertAdjacentElement('afterend',shareBox);\n        }else{\n            postBody.insertAdjacentElement('afterend',shareBox);\n        }\n    }\n});\nfunction shareWebShare(){\n    if(navigator.share){\n        var desc='';\n        var metaDesc=document.querySelector('meta[name=\"description\"]');\n        if(metaDesc){desc=metaDesc.getAttribute('content')||'';}\n        navigator.share({title:document.title,url:window.location.href,text:desc}).catch(function(err){console.log('Share canceled:',err);});\n    }else{\n        copyShareLink();\n    }\n}\nfunction shareTo(platform){\n    var url=encodeURIComponent(window.location.href);\n    var title=encodeURIComponent(document.title);\n    var shareUrl='';\n    if(platform==='weibo'){shareUrl='https://service.weibo.com/share/share.php?url='+url+'&title='+title;}\n    else if(platform==='twitter'){shareUrl='https://twitter.com/intent/tweet?url='+url+'&text='+title;}\n    else if(platform==='facebook'){shareUrl='https://www.facebook.com/sharer/sharer.php?u='+url;}\n    if(shareUrl){window.open(shareUrl,'_blank','width=600,height=500,menubar=no,toolbar=no');}\n}\nfunction copyShareLink(){\n    var url=window.location.href;\n    if(navigator.clipboard && navigator.clipboard.writeText){\n        navigator.clipboard.writeText(url).then(function(){\n            alert('\\u94fe\\u63a5\\u5df2\\u590d\\u5236\\n'+url);\n        }).catch(function(){fallbackCopy(url);});\n    }else{\n        fallbackCopy(url);\n    }\n}\nfunction fallbackCopy(url){\n    var textarea=document.createElement('textarea');\n    textarea.value=url;\n    textarea.style.position='fixed';\n    textarea.style.opacity='0';\n    document.body.appendChild(textarea);\n    textarea.select();\n    try{document.execCommand('copy');alert('\\u94fe\\u63a5\\u5df2\\u590d\\u5236\\n'+url);}catch(e){prompt('\\u8bf7\\u590d\\u5236\\u4e0b\\u9762\\u7684\\u94fe\\u63a5:',url);}\n    document.body.removeChild(textarea);\n}\n</script>",
