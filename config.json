{
    "title": "Wxjxpp的博客",
    "subTitle": "欢迎光临我的小窝",
    "avatarUrl": "https://github.githubassets.com/favicons/favicon.svg",
    "GMEEK_VERSION": "last",
    "allHead": "<script>\ndocument.addEventListener(\"DOMContentLoaded\",function(){\n    var postBody=document.getElementById('postBody');\n    if(postBody){\n        postBody.insertAdjacentHTML('afterend','<div id=\"busuanzi_container_page_pv\" style=\"display:none;float:left;margin-top:8px;font-size:small;\">本文浏览量 <span id=\"busuanzi_value_page_pv\"></span> 次</div>');\n    }\n    var runday=document.getElementById('runday');\n    if(runday){\n        runday.insertAdjacentHTML('afterend','<span id=\"busuanzi_container_site_pv\" style=\"display:none\">总浏览量 <span id=\"busuanzi_value_site_pv\"></span> 次 • </span>');\n        runday.insertAdjacentHTML('afterend','<span id=\"busuanzi_container_site_uv\" style=\"display:none\">访客数 <span id=\"busuanzi_value_site_uv\"></span> • </span>');\n        var vc=document.createElement('script');\n        vc.src='https://vercount.one/js';\n        vc.async=true;\n        document.head.appendChild(vc);\n    }\n    if(postBody){\n        var shareBox=document.createElement('div');\n        shareBox.id='share-box';\n        shareBox.style.cssText='margin-top:24px;padding:16px 0;border-top:1px solid var(--color-border-muted, #d0d7de);text-align:center;font-size:small;clear:both;';\n        shareBox.innerHTML='<span style=\"margin-right:8px;color:var(--color-fg-muted);\">分享到:</span>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareWebShare()\" title=\"分享\" style=\"font-size:small;\">分享</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareTo(\\'weibo\\')\" title=\"微博\" style=\"font-size:small;\">微博</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareTo(\\'twitter\\')\" title=\"Twitter\" style=\"font-size:small;\">Twitter</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:shareTo(\\'facebook\\')\" title=\"Facebook\" style=\"font-size:small;\">Facebook</a>'+\n            '<a class=\"btn btn-invisible\" href=\"javascript:copyShareLink()\" title=\"复制链接\" style=\"font-size:small;\">复制链接</a>';\n        var bottomDiv=postBody.nextElementSibling;\n        if(bottomDiv && bottomDiv.getAttribute('style') && bottomDiv.getAttribute('style').indexOf('float:right')!==-1){\n            bottomDiv.insertAdjacentElement('afterend',shareBox);\n        }else{\n            postBody.insertAdjacentElement('afterend',shareBox);\n        }\n    }\n});\nfunction shareWebShare(){\n    if(navigator.share){\n        var desc='';\n        var metaDesc=document.querySelector('meta[name=\"description\"]');\n        if(metaDesc){desc=metaDesc.getAttribute('content')||'';}\n        navigator.share({title:document.title,url:window.location.href,text:desc}).catch(function(err){console.log('Share canceled:',err);});\n    }else{copyShareLink();}\n}\nfunction shareTo(platform){\n    var url=encodeURIComponent(window.location.href);\n    var title=encodeURIComponent(document.title);\n    var shareUrl='';\n    if(platform==='weibo'){shareUrl='https://service.weibo.com/share/share.php?url='+url+'&title='+title;}\n    else if(platform==='twitter'){shareUrl='https://twitter.com/intent/tweet?url='+url+'&text='+title;}\n    else if(platform==='facebook'){shareUrl='https://www.facebook.com/sharer/sharer.php?u='+url;}\n    if(shareUrl){window.open(shareUrl,'_blank','width=600,height=500,menubar=no,toolbar=no');}\n}\nfunction copyShareLink(){\n    var url=window.location.href;\n    if(navigator.clipboard && navigator.clipboard.writeText){\n        navigator.clipboard.writeText(url).then(function(){alert('链接已复制\\n'+url);}).catch(function(){fallbackCopy(url);});\n    }else{fallbackCopy(url);}\n}\nfunction fallbackCopy(url){\n    var textarea=document.createElement('textarea');\n    textarea.value=url;\n    textarea.style.position='fixed';\n    textarea.style.opacity='0';\n    document.body.appendChild(textarea);\n    textarea.select();\n    try{document.execCommand('copy');alert('链接已复制\\n'+url);}catch(e){prompt('请复制下面的链接:',url);}\n    document.body.removeChild(textarea);\n}\n</script><script>\n// ===== Giscus 评论系统（替换 utteranc.es）=====\ndocument.addEventListener(\"DOMContentLoaded\",function(){\n    var cmButton=document.getElementById('cmButton');\n    var commentsEl=document.getElementById('comments');\n    if(!cmButton||!commentsEl){return;}\n    // 拦截原 click\n    cmButton.onclick=function(e){\n        e.preventDefault();\n        cmButton.disabled=true;\n        cmButton.innerHTML='加载中...';\n        // 清空容器\n        commentsEl.innerHTML='';\n        // 创建 giscus script\n        var s=document.createElement('script');\n        s.src='https://giscus.app/client.js';\n        s.setAttribute('data-repo','Wxjxpp/blog.github.io');\n        s.setAttribute('data-repo-id','R_kgDOTdTnwA');\n        s.setAttribute('data-category','Announcements');\n        s.setAttribute('data-category-id','DIC_kwDOTdTnwM4DBoUB');\n        s.setAttribute('data-mapping','title');\n        s.setAttribute('data-strict','0');\n        s.setAttribute('data-reactions-enabled','1');\n        s.setAttribute('data-emit-metadata','0');\n        s.setAttribute('data-input-position','bottom');\n        s.setAttribute('data-theme',getGiscusTheme());\n        s.setAttribute('data-lang','zh-CN');\n        s.setAttribute('crossorigin','anonymous');\n        s.async=true;\n        commentsEl.appendChild(s);\n        // 监听主题切换\n        setupGiscusThemeSync();\n        // 隐藏按钮\n        setTimeout(function(){\n            var iframe=commentsEl.querySelector('iframe.giscus-frame');\n            if(iframe){\n                cmButton.style.display='none';\n            }\n        },2000);\n        // 兜底：3 秒后隐藏按钮\n        setTimeout(function(){cmButton.style.display='none';},3000);\n    };\n    // 自动展开评论（不用点按钮）\n    setTimeout(function(){cmButton.click();},500);\n});\nfunction getGiscusTheme(){\n    var mode=document.documentElement.getAttribute('data-color-mode');\n    if(mode==='dark'){return 'dark_dimmed';}\n    if(mode==='auto'||!mode){\n        return 'preferred_color_scheme';\n    }\n    return 'light';\n}\nfunction setupGiscusThemeSync(){\n    // 监听主题切换，同步给 giscus iframe\n    var observer=new MutationObserver(function(mutations){\n        for(var m of mutations){\n            if(m.attributeName==='data-color-mode'){\n                var iframe=document.querySelector('iframe.giscus-frame');\n                if(iframe){\n                    var theme=getGiscusTheme();\n                    iframe.contentWindow.postMessage({giscus:{setConfig:{theme:theme}}},'https://giscus.app');\n                }\n            }\n        }\n    });\n    observer.observe(document.documentElement,{attributes:true,attributeFilter:['data-color-mode']});\n}\n\n<script>\ndocument.addEventListener('DOMContentLoaded',function(){var b=document.getElementById('cmButton'),c=document.getElementById('comments');if(!b||!c){return;}b.onclick=function(e){e.preventDefault();b.disabled=true;b.innerHTML='加载中...';c.innerHTML='';var s=document.createElement('script');s.src='https://giscus.app/client.js';s.setAttribute('data-repo','Wxjxpp/blog.github.io');s.setAttribute('data-repo-id','R_kgDOTdTnwA');s.setAttribute('data-category','Announcements');s.setAttribute('data-category-id','DIC_kwDOTdTnwM4DBoUB');s.setAttribute('data-mapping','title');s.setAttribute('data-reactions-enabled','1');s.setAttribute('data-input-position','bottom');var m=document.documentElement.getAttribute('data-color-mode');s.setAttribute('data-theme',m==='dark'?'dark_dimmed':(m==='light'?'light':'preferred_color_scheme'));s.setAttribute('data-lang','zh-CN');s.setAttribute('crossorigin','anonymous');s.async=true;c.appendChild(s);setTimeout(function(){b.style.display='none';},3000);};setTimeout(function(){b.click();},500);});\n<\/script>
<\/script>",
    "indexStyle": "<style>\n#hitokoto-container{margin-bottom:16px;padding:12px 16px;background-color:var(--color-canvas-subtle,#f6f8fa);border-left:3px solid #0969da;border-radius:4px;font-size:14px;line-height:1.6;color:var(--color-fg-muted,#57606a);display:flex;align-items:center;gap:8px;flex-wrap:wrap;}\n#hitokoto-text{flex:1;min-width:0;font-style:italic;}\n#hitokoto-from{font-size:12px;color:var(--color-fg-subtle,#6e7781);}\n#hitokoto-refresh{cursor:pointer;color:#0969da;font-size:12px;white-space:nowrap;user-select:none;}\n#hitokoto-refresh:hover{text-decoration:underline;}\n</style>",
    "indexScript": "<script>\ndocument.addEventListener(\"DOMContentLoaded\",function(){\n    var content=document.getElementById('content');\n    if(!content){return;}\n    var hitokotoContainer=document.createElement('div');\n    hitokotoContainer.id='hitokoto-container';\n    hitokotoContainer.innerHTML='<span id=\"hitokoto-text\">加载中...</span><span id=\"hitokoto-from\"></span><span id=\"hitokoto-refresh\" onclick=\"loadHitokoto()\">换一句</span>';\n    var firstDiv=content.querySelector('div');\n    if(firstDiv){firstDiv.insertAdjacentElement('afterend',hitokotoContainer);}else{content.insertBefore(hitokotoContainer,content.firstChild);}\n    loadHitokoto();\n});\nfunction loadHitokoto(){\n    var textEl=document.getElementById('hitokoto-text');\n    var fromEl=document.getElementById('hitokoto-from');\n    if(!textEl){return;}\n    var xhr=new XMLHttpRequest();\n    xhr.open('GET','https://v1.hitokoto.cn/?encode=json&c=d&c=i&c=k');\n    xhr.responseType='text';\n    xhr.timeout=5000;\n    xhr.onload=function(){\n        try{var data=JSON.parse(xhr.response);textEl.textContent=data.hitokoto||'生活总会有希望。';fromEl.textContent=data.from?('—— '+data.from):'';}\n        catch(e){textEl.textContent='人生如逆旅，我亦是行人。';fromEl.textContent='—— 苏轼';}\n    };\n    xhr.onerror=xhr.ontimeout=function(){textEl.textContent='人生如逆旅，我亦是行人。';fromEl.textContent='—— 苏轼';};\n    xhr.send();\n}\n</script>"
}
